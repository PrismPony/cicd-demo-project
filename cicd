#!/bin/bash
IMAGE_NAME="gteam/cicd-cli:latest"

if ! command -v docker &> /dev/null; then
    echo "Error: Docker is not installed."
    exit 1
fi

if [ -z "$(docker images -q $IMAGE_NAME 2> /dev/null)" ]; then
    echo "CLI image not found. Please run ./install.sh first."
    exit 1
fi

docker run --rm \
    --network host \
    -v "$(pwd):/workspace" \
    -w /workspace \
    $IMAGE_NAME "$@"
